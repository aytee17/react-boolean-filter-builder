{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist"
  },
  "include": [
    "index.ts",
    "Filter.tsx",
    "types.ts",
    "hooks/**/*",
    "components/**/*",
    "services/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
